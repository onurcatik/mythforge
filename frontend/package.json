{
  "name": "forge-frontend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.5.1",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "tsgo -b && vite build",
    "build:capacitor": "tsgo -b && cross-env CAPACITOR_BUILD=true vite build",
    "cap:android": "pnpm build:capacitor && npx cap sync android && npx cap run android",
    "cap:ios": "pnpm build:capacitor && npx cap sync ios && npx cap run ios",
    "preview": "vite preview",
    "typecheck": "tsgo --noEmit",
    "check": "biome check ./src",
    "check:fix": "biome check ./src --write",
    "lint": "biome lint ./src",
    "lint:fix": "biome lint ./src --write",
    "format": "biome format ./src --write",
    "format:api": "biome format ./src/api/generated --write --no-errors-on-unmatched",
    "test": "vitest",
    "test:run": "vitest run",
    "generate:api": "./scripts/generate-api.sh",
    "prepare": "cd .. && husky ./frontend/.husky"
  },
  "dependencies": {
